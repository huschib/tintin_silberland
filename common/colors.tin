#NOP { /**
 *  @class colors
 *
 *  FUNCTION @farbig: Gibt den Namen der Farbe farbig zurueck.
 *      TODO: Optionaler zweiter Parameter um irgendeinen Text farbig zu machen?
 *
 *  Debug modus:
 *    ALIAS colorshow: Zeigt verschiedene Farbtabellen an.
 */};

#CLASS colors KILL;
#CLASS colors OPEN;

#NOP #READ common/util.tin;

#IF {$DEBUG_MODE == 1} {

#ALIAS _colorRowShow {
  #LIST _line CREATE {{}};
  #LOOP 65 70 rowUpOrdI {
    #FORMAT rowUpCharI {%a} $rowUpOrdI;
    #MATH rowLowOrdI {$rowUpOrdI + 32};
    #FORMAT rowLowCharI {%a} $rowLowOrdI;
    #LOCAL rowVg {%1};
    #LOCAL rowHg {%2};
    #REPLACE rowVg x $rowLowCharI;
    #REPLACE rowHg X $rowUpCharI;
    #LIST _line ADD { <$rowVg><$rowHg> $rowVg/$rowHg <099> };
  };
  #LIST _line collapse { };
  #ECHO {$_line};
  #UNVAR _line;
  #UNVAR rowUpCharI;
  #UNVAR rowLowCharI;
};

#ALIAS colorshow {
  #SWITCH { "%1" } {
  #CASE { "hilfe" } {
    #ECHO {Syntax: colorshow [hilfe]};
    #ECHO {Syntax: colorshow ampullen};
    #ECHO {        colorshow <vordergrund> [<hintergrund>]};
    #ECHO { Ohne Parameter: Zeigt 8bit ANSI Kombinationen};
    #ECHO { Mit Parameter "aaa" oder "aaa AAA" für entsprechende};
    #ECHO { Farbkombinationen.  Ein einzelner Wert kann x (bzw. X) und};
    #ECHO { einer y (bzw. Y) sein.  Dieser wird dann durch die Werte};
    #ECHO { a bis f rotiert.  Also "fax" zeigt alle Farbtöne von rot};
    #ECHO { (faa) bis magenta (faf) an.};
    #ECHO { Parameter "ampullen" zeigt die Farbzuweisungen der Ampullen an};
  };
  #CASE { "ampullen" } {
    #FOREACH {*farbCodes[]} {_farbe} {
      #ECHO { @farbig{$_farbe}};
    };
  };
  #CASE { "" } {
    #ECHO { <170> Bold <099> <270> Dim  <099> <370> Ital <099> <470> Untr <099> <570> Blink <099> <770> Revr <099>};
    #loop 0 7 hg {
      #ECHO { <01$hg> 01$hg <099>  <02$hg> 02$hg <099>  <03$hg> 03$hg <099>  <04$hg> 04$hg <099>  <05$hg> 05$hg <099>  <06$hg> 06$hg <099>  <07$hg> 07$hg <099>};
    };
    #UNVAR hg;
  };
  #DEFAULT {
    #VAR vg {%1};
    #VAR hg {%2};
    #IF { "$hg" == "" } { #VAR hg {AAA}; };
    #REGEXP {$vg$hg} {{^([a-fxy]{3})([A-FXY]{3})$}} {
      #REGEXP {$vg$hg} {%!{[xX]}} { #VAR hasX 1; } { #VAR hasX 0; };
      #REGEXP {$vg$hg} {%!{[yY]}} { #VAR hasY 1; } { #VAR hasY 0; };
      #IF {$hasX} {
        #IF {$hasY} {
          #LOOP 65 70 upOrdI {
            #FORMAT upCharI {%a} $upOrdI;
            #MATH lowOrdI {$upOrdI + 32};
            #FORMAT lowCharI {%a} $lowOrdI;
            #VAR vgCopy $vg;
            #VAR hgCopy $hg;
            #REPLACE vgCopy y $lowCharI;
            #REPLACE hgCopy Y $upCharI;
            _colorRowShow {$vgCopy} {$hgCopy};
          };
          #UNVAR upCharI;
          #UNVAR lowCharI;
          #UNVAR upOrdI;
          #UNVAR lowOrdI;
          #UNVAR vgCopy;
          #UNVAR hgCopy;
        } {
          _colorRowShow {$vg} {$hg};
        };
      }; #ELSE {
        #IF {$hasY} {
          #ECHO {You've given a "y" without an "x" - that does not make sense.};
        } {
          #ECHO {<$vg><$hg> That was easy! <099>};
        };
      };
      #UNVAR hasX;
      #UNVAR hasY;
    } {
      #ECHO {Invalid parameter %1.  Should be three values from a-f or x or y.};
      #ECHO {For example: "fax".};
    };
    #UNVAR vg;
    #UNVAR hg;
  };
  };
};
debug_msg {  <129>colorshow<288> geladen<099>};

};  #NOP { DEBUG_MODE };


#NOP { /**
 TODO: Bunt muesste in @farbig gesondert behandelt werden
 */};
