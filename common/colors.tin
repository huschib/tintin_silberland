}

#FUNCTION {split_by_length} {
    #LOCAL {input_string} {%1};
    #LOCAL {chunk_length} {%2};
    #LIST {local_list} {clear};
    
    #FORMAT {total_length} {%L} {$input_string};
    #LOCAL {index} {0};
    
    #WHILE {$index <= $total_length} {
        #LIST {local_list} {ADD} {@substr{$input_string;$index;$chunk_length}};
        #MATH {index} {$index + $chunk_length};
    };
    #VAR {result} {$local_list};
}

#FUNCTION {zip_lists} {
    #LOCAL {list_a} {%1};
    #LOCAL {list_b} {%2};
    #LOCAL {len_a} {0};
    #LOCAL {len_b} {0};
    #LOCAL {max_len} {0};
    #LOCAL {index} {1};
    #LOCAL {combined_list} {};

    #LIST {list_a} {SIZE} {len_a};
    #LIST {list_b} {SIZE} {len_b};
    #LIST {combined_list} {CLEAR};

    #MATH {min_len} {$len_a < $len_b ? $len_a : $len_b};

    #WHILE {$index <= $min_len} {
        #LIST {combined_list} {ADD} {$list_a[$index]};
        #LIST {combined_list} {ADD} {$list_b[$index]};
        #MATH {index} {$index + 1};
    };
    #VAR {result} {$combined_list};
}

#NOP { /**
 *  @fn farbig
 *  @brief Gibt den gegebenen Text farbig zurueck.
 *
 *  @param  1   Eine Farbe mit oder ohne e am Ende (z.B. "rot" oder "rote")
 */};
#FUNCTION farbig {
  #LOCAL _farbName %1;
  #REGEXP {$_farbName} {{.*}-{.*}} {
    #VAR result {@farbig{&1}-@farbig{&2}};
  } {
    #SWITCH { "$_farbName" } {
      #CASE { "{bunt|bunte}" } {
        #LIST {farbSchritte} CREATE {<aaf>;<ffa>;<faa>;<afa>;<aff>};
        #VAR resultList {@zip_lists{{$farbSchritte};{@split_by_length{$_farbName;1}}}};
        #LIST resultList COLLAPSE {};
        #VAR result {$resultList<099>};
      };
      #CASE { "{regenbogenfarben|regenbogenfarbene}" } {
        #LIST {farbSchritte} CREATE {<faa>;<fca>;<ffa>;<cfa>;<afa>;<acf>;<aaf>;<dad>;<bab>};
        #VAR resultList {@zip_lists{{$farbSchritte};{@split_by_length{$_farbName;2}}}};
        #LIST resultList COLLAPSE {};
        #VAR result {$resultList<099>};
      };
      #CASE { "{magischbunt|magischbunte}" } {
        #LIST farbSchritte CREATE {<aae>;<ade>;<bae>;<eae>;<aec>};
        #VAR resultList {@zip_lists{{$farbSchritte};{@split_by_length{$_farbName;3}}}};
        #LIST resultList COLLAPSE {};
        #VAR result {<BAB>$resultList<099>};
      };
      #CASE { "{lustigbunt|lustigbunte}" } {
        #LIST farbSchritte CREATE {<bfa>;<ffa>;<fca>;<fcf>;<aff>};
        #LIST farbSchritte SHUFFLE;
        #VAR resultList {@zip_lists{{$farbSchritte};{@split_by_length{$_farbName;3}}}};
        #LIST resultList COLLAPSE {};
        #VAR result {$resultList<099>};
      };
      #DEFAULT {
        #LOCAL _farbCode {$farbCodes[$_farbName]};
        #IF { "$_farbCode" == "" } {
          #LOCAL _farbCode {$farbCodes[${_farbName}e]};
        };
        #VAR result {$_farbCode$_farbName<099>};
      };
    };
  };
};
debug_msg {  <129>farbig<288> geladen<099>};

#CLASS colors CLOSE;